# HTTP server
SERVER_HOST=localhost
SERVER_PORT=8080

# Logger settings
LOGGER_LEVEL=info
LOGGER_BUFFER_SIZE=1000
LOGGER_MODE=console

# Postgres connection
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5433
DB_POSTGRES_USER=user
DB_POSTGRES_PASSWORD=password
DB_POSTGRES_DBNAME=dbname
DB_POSTGRES_SSLMODE=disable
DB_POSTGRES_MAXOPENCONNS=25
DB_POSTGRES_MAXIDLECONNS=25
DB_POSTGRES_CONNMAXLIFETIME=5s

# Redis connection and cache sizes
DB_REDIS_PORT=6379
DB_REDIS_HOST=localhost
DB_REDIS_PASSWORD=password
DB_REDIS_DB=0
DB_REDIS_CACHESIZE=1000
DB_REDIS_CACHERETRYSIZE=100

# DB timeouts
DB_TIMEOUTS_WRITE=3s
DB_TIMEOUTS_READ=2s
DB_TIMEOUTS_LONG=30s

# Gin mode (release/debug)
GIN_MODE=release

# API key for protected endpoints
AUTH_APIKEY=your_api_key_here

# Stats window (minutes)
STATS_TIME_WINDOW_MINUTES=60

# Webhook receiver URL
WEBHOOK_URL=http://localhost:9090/webhook

# Incident validation limits
INCIDENT_TITLEMINLENGTH=5
INCIDENT_TITLEMAXLENGTH=100
INCIDENT_DESCRMINLENGTH=5
INCIDENT_DESCRMAXLENGTH=1000

# Retry strategy
RETRY_ATTEMPTS=3
RETRY_DELAY=1s
RETRY_BACKOFF=2

# Ngrok auth token (optional for tunneling webhook stub)
NGROK_AUTHTOKEN =your_ngrok_auth_token_here